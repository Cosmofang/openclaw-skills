# RIC Registry Environment Variables

# Port to listen on (default: 3000)
PORT=3000

# Absolute path to the SQLite database file
# Defaults to: packages/registry/data/registry.db
RIC_DB_PATH=./data/registry.db

# Admin key for grade management endpoint (POST /v1/audit/grade)
# CHANGE THIS in production!
RIC_ADMIN_KEY=change-me-in-production
